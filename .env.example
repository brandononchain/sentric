# Sentric Configuration
# Copy to .env and fill in your values

# Helius API (required for live ingestion)
HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_WS_URL=wss://atlas-mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Server
PORT=3000
HOST=0.0.0.0

# x402 Payment
TREASURY_WALLET=YOUR_SOLANA_WALLET_ADDRESS
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
SIGNAL_PRICE_USDC=0.001
CONSENSUS_PRICE_USDC=0.005

# Signal Store
SIGNAL_TTL_SECONDS=300
MAX_SIGNALS=10000

# Dev mode — set to true to bypass x402 payment verification
SENTRY_DEV_MODE=true

# Redis (optional — falls back to in-memory store)
REDIS_URL=

# === Social / X enrichment (optional) ===
# Detect KOL tweets naming tokens BEFORE/as they buy — the earliest signal.
# SOCIAL_PROVIDER: "x" (official X API), "socialdata" (3rd-party, ~100x cheaper reads), or "none"
SOCIAL_PROVIDER=none
# Official X API v2 bearer token (pay-per-use; expensive for fast polling)
X_BEARER_TOKEN=
# SocialData.tools API key (cheaper read alternative)
SOCIALDATA_API_KEY=
# Tiered poll intervals in ms — S-tier (Ansem etc) fast, A mid, B/C slow
SOCIAL_FAST_POLL_MS=15000
SOCIAL_MID_POLL_MS=60000
SOCIAL_SLOW_POLL_MS=300000
